# =============================================================================
# HARMONIA - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# This is the single source of truth for all environment variables
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Neon or local Docker)
# For local Docker: postgresql://postgres:password@localhost:5433/harmonia
# (Port 5433 avoids conflict with existing Postgres on 5432)
# Required by: DB package, drizzle-kit, API
DATABASE_URL="postgresql://postgres:password@localhost:5433/harmonia"

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------
# Secret key (generate with: openssl rand -base64 32)
# Required by: Auth package
BETTER_AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Base URL for auth callbacks. For Spotify OAuth use 127.0.0.1 (Spotify rejects localhost).
# Required by: Auth package. Open the app at this URL when testing (e.g. http://127.0.0.1:3001).
BETTER_AUTH_URL="http://127.0.0.1:3001"

# Allowed CORS origin (must match BETTER_AUTH_URL when running locally)
# Required by: Auth package
CORS_ORIGIN="http://127.0.0.1:3001"

# -----------------------------------------------------------------------------
# SPOTIFY (Optional - Phase 1)
# -----------------------------------------------------------------------------
# Spotify OAuth credentials from Spotify Developer Dashboard
# (https://developer.spotify.com/dashboard). Create an app and set:
#   Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/spotify
#   e.g. local: http://127.0.0.1:3001/api/auth/callback/spotify
#   (Spotify does not allow "localhost"; use 127.0.0.1 and open the app at
#    http://127.0.0.1:3001)
#   Production: https://your-domain.com/api/auth/callback/spotify
# Required by: Auth package, packages/music (when Spotify features enabled)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# OPENAI (Optional - Phase 3)
# -----------------------------------------------------------------------------
# For track embeddings (text-embedding-3-small)
# Required by: Worker (embeddings task)
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# GROQ (Optional - Phase 3)
# -----------------------------------------------------------------------------
# For LLM classification (mood, themes, etc.) via Groq GPT-OSS 120B
# Required by: @harmonia/brain (llm-classify)
GROQ_API_KEY=""

# -----------------------------------------------------------------------------
# CRON (Optional)
# -----------------------------------------------------------------------------
# Secret used by Vercel/GitHub cron to trigger organize.run
# Required by: apps/web /api/cron/organize route and organize.run router
CRON_SECRET=""
# Optional: user ID to organize via cron
CRON_USER_ID=""
