# =============================================================================
# HARMONIA - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string (Neon or local Docker)
# Required by: DB package, API app
DATABASE_URL="postgresql://postgres:password@localhost:5433/harmonia"

# -----------------------------------------------------------------------------
# BASE CONFIGURATION
# -----------------------------------------------------------------------------
# Node environment (development, production, local)
NEXT_PUBLIC_NODE_ENV="local"

# API URL - Base URL for API requests (auth, RPC)
# Required by: All apps. API runs on this URL.
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Allowed origin pattern for CORS validation (*, URL, or wildcard like *.domain.com)
NEXT_PUBLIC_ALLOWED_ORIGIN="*"

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
# Web app URL
NEXT_PUBLIC_WEB_URL="http://localhost:3001"

# Dashboard app URL
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3003"

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Better Auth secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Spotify OAuth (optional)
# Redirect URI: {NEXT_PUBLIC_API_URL}/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# AI / EMBEDDINGS (Optional)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=""
GROQ_API_KEY=""

# -----------------------------------------------------------------------------
# CRON (Optional)
# -----------------------------------------------------------------------------
# Secret for Vercel cron to trigger organize.run
CRON_SECRET=""

# -----------------------------------------------------------------------------
# OBSERVABILITY (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME="harmonia"
OTEL_SAMPLING_RATE="1"
OTEL_ENABLED="false"
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=""
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=""
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_EXPORTER_OTLP_COMPRESSION="gzip"
